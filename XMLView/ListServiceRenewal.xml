<view>
    <columns>
        <column name="customer" order="10">
            <widget type="text" fieldname="customer_name"/>
        </column>
        <column name="service" order="20">
            <widget type="text" fieldname="title"/>
        </column>
        <column name="service-identifier" order="30">
            <widget type="text" fieldname="service_identifier"/>
        </column>
        <column name="product" order="40">
            <widget type="text" fieldname="product_reference"/>
        </column>
        <column name="service-type" order="50">
            <widget type="text" fieldname="service_type_label"/>
        </column>
        <column name="provider-name" order="60">
            <widget type="text" fieldname="provider_name"/>
        </column>
        <column name="expiration-date" order="70">
            <widget type="date" fieldname="expiration_date"/>
        </column>
        <column name="days-left" order="80" display="right">
            <widget type="number" fieldname="days_left" decimal="0">
                <option color="danger">lt:0</option>
                <option color="warning">lt:8</option>
            </widget>
        </column>
        <column name="status" order="90">
            <widget type="text" fieldname="status_label"/>
        </column>
        <column name="cycle-status" order="100">
            <widget type="text" fieldname="cycle_status"/>
        </column>
        <column name="last-quote" order="110">
            <widget type="text" fieldname="last_quote_code"/>
        </column>
        <column name="last-invoice" order="120">
            <widget type="text" fieldname="last_invoice_code"/>
        </column>
        <column name="amount" order="130" display="right">
            <widget type="money" fieldname="amount"/>
        </column>
    </columns>
    <rows>
        <row type="status">
            <option color="warning" fieldname="status" title="suspended">suspended</option>
            <option color="dark" fieldname="status" title="cancelled">cancelled</option>
            <option color="danger" fieldname="status" title="expired">expired</option>
        </row>
    </rows>
</view>
